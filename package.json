{
  "name": "datev-bridge",
  "version": "0.1.0",
  "description": "Convert CSV exports from payment tools (Stripe, …) into DATEV EXTF Buchungsstapel — adapter-based with declarative, versioned mapping. Format-compatible, not DATEV-certified.",
  "type": "module",
  "bin": {
    "datev-bridge": "dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "configs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "datev",
    "extf",
    "buchungsstapel",
    "stripe",
    "accounting",
    "buchhaltung",
    "skr03",
    "skr04",
    "csv",
    "germany"
  ],
  "author": "Julian Abt",
  "license": "MIT",
  "homepage": "https://github.com/juli1111/datev-bridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juli1111/datev-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/juli1111/datev-bridge/issues"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "csv-parse": "^5.5.6",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "eslint": "^9.9.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0",
    "vitest": "^2.0.5"
  }
}
